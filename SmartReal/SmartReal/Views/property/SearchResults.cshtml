@model List<Property>
@{
    ViewData["Title"] = "نتائج البحث | SYRELIS";

    var city = Context.Request.Query["city"].ToString();
    var type = Context.Request.Query["type"].ToString();
    var price = Context.Request.Query["price"].ToString();

    var searchTitle = "نتائج البحث";
    if (!string.IsNullOrEmpty(city))
        searchTitle += " في " + city;
    if (!string.IsNullOrEmpty(type))
        searchTitle += " - " + type;
    if (!string.IsNullOrEmpty(price))
        searchTitle += " (حتى $" + price + ")";
}

<nav class="navbar">
    <img class="logo" src="~/images/hero.png" alt="SYRELIS" />
    <ul class="nav-links">
        <li><a href="/">الرئيسية</a></li>
        <li><a href="#" id="announceLink">أعلن عن عقارك</a></li>
        <li><a href="/Property/Search">ابحث عن عقارك</a></li>
        <li><a href="/Home/About">حسابي</a></li>
        <li><a href="#" id="contactNavLink">تواصل معنا</a></li>
    </ul>
</nav>

<div class="container">
    <div class="province-header">
        <div class="header-wrapper">
            <a href="/Property/Search" class="back-button">
                <i class="fas fa-arrow-right"></i>
            </a>
            <div class="left-section">
                <div class="province-info">
                    <div class="province-title">
                        <h1 id="provinceName">@searchTitle</h1>
                        <p>@Model.Count عقار</p>
                    </div>
                </div>
            </div>
            <div class="search-info-box" id="searchInfoBox">
                <div class="search-info-item">
                    <i class="fas fa-city"></i>
                    <span class="label">المدينة:</span>
                    <span class="value" id="searchCity">
                        @if (!string.IsNullOrEmpty(city))
                        {
                            <text>@city</text>
                        }
                        else
                        {
                            <text>كل المدن</text>
                        }
                    </span>
                </div>
                <div class="search-info-divider"></div>
                <div class="search-info-item">
                    <i class="fas fa-building"></i>
                    <span class="label">نوع العقار:</span>
                    <span class="value" id="searchType">
                        @if (!string.IsNullOrEmpty(type))
                        {
                            <text>@type</text>
                        }
                        else
                        {
                            <text>كل الأنواع</text>
                        }
                    </span>
                </div>
                <div class="search-info-divider"></div>
                <div class="search-info-item">
                    <i class="fas fa-tag"></i>
                    <span class="label">السعر:</span>
                    <span class="value" id="searchPrice">
                        @if (!string.IsNullOrEmpty(price))
                        {
                            <text>$ @price</text>
                        }
                        else
                        {
                            <text>جميع الأسعار</text>
                        }
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="properties-grid" id="propertiesGrid">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                var mainImage = item.Images.FirstOrDefault(i => i.IsMain)?.ImageUrl ?? "/images/default.jpg";
                <div class="property-card">
                    <div class="property-image">
                        <span class="badge badge-for-sale">@item.Status</span>
                        <div class="overlay"></div>
                        <img src="@mainImage" alt="@item.Title" onerror="this.src='/images/default.jpg'">
                    </div>
                    <div class="property-content">
                        <h3 class="property-title">@item.Title</h3>
                        <div class="property-price">
                            <span class="price-original">@item.Price.ToString("N0") @item.PriceCurrency</span>
                        </div>
                        <div class="property-location">
                            <i class="fas fa-map-marker-alt"></i>
                            <span>@(item.City?.NameAr ?? "") - @(item.Neighborhood?.NameAr ?? "")</span>
                        </div>
                        <div class="property-type">
                            <i class="fas fa-building"></i>
                            <span>@(item.PropertyType?.NameAr ?? "نوع غير محدد")</span>
                        </div>
                        <div class="property-meta">
                            <span><i class="fas fa-user"></i> @(item.Advertiser?.FullName ?? "معلن")</span>
                        </div>
                    </div>
                    <div class="property-footer">
                        <div class="footer-features">
                            <div class="footer-item"><i class="fas fa-door-open"></i> @item.Rooms</div>
                            <div class="footer-item"><i class="fas fa-ruler-combined"></i> @item.Area م²</div>
                            <div class="footer-item"><i class="fas fa-bath"></i> @item.Bathrooms</div>
                        </div>
                        <button class="btn-favorite" onclick="handleFavorite(@item.Id, this)" data-id="@item.Id">
                            <i class="far fa-heart"></i>
                            <span>أضف للمفضلة</span>
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="grid-column: 1/-1; text-align: center; padding: 60px 20px; color: white;">
                <i class="fas fa-search" style="font-size: 60px; color: var(--gold); margin-bottom: 20px; display: block;"></i>
                <h2 style="color: var(--gold-light); margin-bottom: 15px;">لا توجد عقارات مطابقة للبحث</h2>
                <p style="color: rgba(255,255,255,0.7); font-size: 18px;">جرب تعديل معايير البحث أو ابحث عن مدينة أخرى</p>
                <a href="/Property/Search" style="display: inline-block; margin-top: 25px; padding: 12px 35px; background: var(--gold); color: var(--dark); border-radius: 30px; text-decoration: none; font-weight: 700; transition: 0.3s;">
                    <i class="fas fa-arrow-right"></i> العودة للبحث
                </a>
            </div>
        }
    </div>
</div>

<script>
    function getFavorites() { return JSON.parse(localStorage.getItem("syrelis_favorites") || "[]"); }
    function isFavorite(id) {
        var favs = getFavorites();
        for (var i = 0; i < favs.length; i++) {
            if (favs[i].id === id) return true;
        }
        return false;
    }
    function toggleFavorite(id, data) {
        var favs = getFavorites();
        var idx = -1;
        for (var i = 0; i < favs.length; i++) {
            if (favs[i].id === id) { idx = i; break; }
        }
        if (idx > -1) {
            favs.splice(idx, 1);
            localStorage.setItem("syrelis_favorites", JSON.stringify(favs));
            return false;
        } else {
            favs.unshift(data);
            localStorage.setItem("syrelis_favorites", JSON.stringify(favs));
            return true;
        }
    }

    var favBtns = document.querySelectorAll('.btn-favorite');
    for (var i = 0; i < favBtns.length; i++) {
        var btn = favBtns[i];
        var id = parseInt(btn.dataset.id);
        if (isFavorite(id)) {
            btn.classList.add('added');
            btn.querySelector('i').className = 'fas fa-heart';
            btn.querySelector('span').textContent = 'في المفضلة';
        }
    }

    function handleFavorite(id, btn) {
        var card = btn.closest('.property-card');
        var data = {
            id: id,
            title: card.querySelector('.property-title').textContent,
            price: card.querySelector('.price-original').textContent,
            location: card.querySelector('.property-location span').textContent,
            type: card.querySelector('.property-type span').textContent,
            img: card.querySelector('.property-image img').src,
            agent: 'معلن'
        };
        var added = toggleFavorite(id, data);
        if (added) {
            btn.classList.add('added');
            btn.querySelector('i').className = 'fas fa-heart';
            btn.querySelector('span').textContent = 'في المفضلة';
            showToast('✓ تمت الإضافة للمفضلة');
        } else {
            btn.classList.remove('added');
            btn.querySelector('i').className = 'far fa-heart';
            btn.querySelector('span').textContent = 'أضف للمفضلة';
            showToast('✓ تمت الإزالة من المفضلة');
        }
    }

    function showToast(msg) {
        var t = document.createElement('div');
        t.style.cssText = 'position:fixed;bottom:50%;left:50%;transform:translateX(-50%);background:#f3f8ff;color:#042347;padding:12px 28px;border-radius:40px;font-weight:800;z-index:999999;box-shadow:0 10px 30px rgba(0,0,0,0.3);';
        t.textContent = msg;
        document.body.appendChild(t);
        setTimeout(function () { t.remove(); }, 2000);
    }

    document.getElementById('announceLink').onclick = function (e) { e.preventDefault(); window.location.href = '/Home/About?tab=addProperty'; };
    document.getElementById('contactNavLink').onclick = function (e) { e.preventDefault(); window.location.href = '/#contactSection'; };
</script>