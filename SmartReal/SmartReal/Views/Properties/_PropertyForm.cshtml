@model RealEstateWebApp.ViewModels.PropertyUpsertViewModel

<div class="row g-3">
    <div class="col-md-3">
        <label asp-for="Code" class="form-label"></label>
        <input asp-for="Code" class="form-control" />
        <span asp-validation-for="Code" class="text-danger"></span>
    </div>
    <div class="col-md-9">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Price" class="form-label">السعر</label>
        <input asp-for="Price" class="form-control" type="number" step="0.01" min="0.01" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>
    <div class="col-md-2">
        <label asp-for="PriceCurrency" class="form-label">العملة</label>
        <input asp-for="PriceCurrency" class="form-control" />
        <span asp-validation-for="PriceCurrency" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Area" class="form-label">المساحة</label>
        <input asp-for="Area" class="form-control" type="number" step="0.01" min="0.01" />
        <span asp-validation-for="Area" class="text-danger"></span>
    </div>
    <div class="col-md-2">
        <label asp-for="Rooms" class="form-label">الغرف</label>
        <input asp-for="Rooms" class="form-control" type="number" min="0" step="1" />
        <span asp-validation-for="Rooms" class="text-danger"></span>
    </div>
    <div class="col-md-2">
        <label asp-for="Bathrooms" class="form-label">الحمامات</label>
        <input asp-for="Bathrooms" class="form-control" type="number" min="0" step="1" />
        <span asp-validation-for="Bathrooms" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Floor" class="form-label">الطابق</label>
        <input asp-for="Floor" class="form-control" type="number" min="0" max="100" step="1" />
        <span asp-validation-for="Floor" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="PropertyTypeId" class="form-label">نوع العقار</label>
        <select asp-for="PropertyTypeId" asp-items="Model.PropertyTypes" class="form-select"></select>
        <span asp-validation-for="PropertyTypeId" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Status" class="form-label">الحالة</label>
        <select asp-for="Status" class="form-select">
            <option value="للبيع">للبيع</option>
            <option value="للإيجار">للإيجار</option>
        </select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="ClusterId" class="form-label">المجموعة</label>
        <select asp-for="ClusterId" asp-items="Model.Clusters" class="form-select">
            <option value="">غير مصنف</option>
        </select>
        <span asp-validation-for="ClusterId" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="CityId" class="form-label">المدينة</label>
        <select asp-for="CityId" asp-items="Model.Cities" class="form-select" id="citySelect"></select>
        <span asp-validation-for="CityId" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="NeighborhoodId" class="form-label">الحي</label>
        <select asp-for="NeighborhoodId" asp-items="Model.Neighborhoods" class="form-select" id="neighborhoodSelect"></select>
        <span asp-validation-for="NeighborhoodId" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Address" class="form-label">العنوان</label>
        <input asp-for="Address" class="form-control" />
        <span asp-validation-for="Address" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Latitude" class="form-label">Latitude</label>
        <input asp-for="Latitude" class="form-control" id="Latitude" />
        <span asp-validation-for="Latitude" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Longitude" class="form-label">Longitude</label>
        <input asp-for="Longitude" class="form-control" id="Longitude" />
        <span asp-validation-for="Longitude" class="text-danger"></span>
    </div>
    <div class="col-md-6 d-flex align-items-end">
        <button type="button" class="btn btn-outline-primary" id="useCurrentLocationBtn">
            استخدام موقعي الحالي
        </button>
    </div>
    <div class="col-md-12">
        <label class="form-label">تحديد الموقع عبر Google Maps</label>
        <div id="propertyMap" class="rounded-3 border" style="height: 320px;"></div>
        <small class="text-muted">انقر على الخريطة لتحديد موقع العقار بدقة.</small>
    </div>
    <div class="col-md-3 d-flex align-items-center">
        <div class="form-check mt-4">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label">نشط</label>
        </div>
    </div>
    <div class="col-md-12">
        <label asp-for="Description" class="form-label">الوصف</label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <div class="col-md-12">
        <label asp-for="ImageFiles" class="form-label">صور العقار</label>
        <input asp-for="ImageFiles" type="file" class="form-control" multiple accept="image/*" id="imageInput" />
        <span asp-validation-for="ImageFiles" class="text-danger"></span>
    </div>
    <div class="col-md-12" id="imagePreviewContainer"></div>
</div>