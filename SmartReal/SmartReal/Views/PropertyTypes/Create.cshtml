@model RealEstateWebApp.Models.PropertyType
@{
    ViewData["Title"] = "إضافة نوع";
}

<h1 class="h4 mb-3">إضافة نوع عقار</h1>
<form asp-action="Create" method="post" class="card p-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="NameAr" class="form-label"></label>
        <input asp-for="NameAr" class="form-control" />
    </div>
    <button class="btn btn-primary" type="submit">حفظ</button>
</form>