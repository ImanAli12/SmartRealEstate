@model RealEstateWebApp.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "الرئيسية";
}

<section class="hero mb-4">
    <div class="row align-items-center">
        <div class="col-lg-7">
            <h1 class="display-6 fw-bold mb-3">ابحث عن عقارك المثالي في سوريا</h1>
            <p class="mb-0">منصة متكاملة للشراء والإيجار مع فلاتر ذكية وتوصيات مبنية على تحليل البيانات.</p>
        </div>
        <div class="col-lg-5 mt-3 mt-lg-0">
            <form asp-controller="Properties" asp-action="Search" method="get" class="bg-white text-dark p-3 rounded-4 shadow-sm">
                <div class="mb-2">
                    <label class="form-label">المدينة</label>
                    <select name="CityId" class="form-select">
                        <option value="">كل المدن</option>
                        @foreach (var city in Model.Cities)
                        {
                            <option value="@city.Id">@city.NameAr</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">نوع العقار</label>
                    <select name="PropertyTypeId" class="form-select">
                        <option value="">كل الأنواع</option>
                        @foreach (var type in Model.PropertyTypes)
                        {
                            <option value="@type.Id">@type.NameAr</option>
                        }
                    </select>
                </div>
                <button class="btn btn-primary w-100" type="submit">بحث سريع</button>
            </form>
        </div>
    </div>
</section>

<section class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0">أحدث العقارات</h2>
        <a asp-controller="Properties" asp-action="Index" class="btn btn-sm btn-outline-primary">عرض الكل</a>
    </div>
    <div class="row g-3">
        @foreach (var property in Model.LatestProperties)
        {
            @await Html.PartialAsync("_PropertyCard", property)
        }
    </div>
</section>

@if (Model.HasPersonalizedRecommendations)
{
    <section class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h4 mb-0">مقترحات مبنية على تفضيلاتك</h2>
            <a asp-controller="Favorites" asp-action="MyFavorites" class="btn btn-sm btn-outline-primary">إدارة المفضلة</a>
        </div>
        <div class="row g-3">
            @foreach (var property in Model.PersonalizedRecommendations)
            {
                @await Html.PartialAsync("_PropertyCard", property)
            }
        </div>
    </section>
}

<section>
    <h2 class="h4 mb-3">عقارات مميزة</h2>
    <div class="row g-3">
        @foreach (var property in Model.FeaturedProperties)
        {
            @await Html.PartialAsync("_PropertyCard", property)
        }
    </div>
</section>
