@model IEnumerable<RealEstateWebApp.Models.Neighborhood>
@{
    ViewData["Title"] = "الأحياء";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">الأحياء</h1>
    <a asp-action="Create" class="btn btn-primary">حي جديد</a>
</div>

<table class="table table-striped bg-white">
    <thead><tr><th>الحي</th><th>المدينة</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.NameAr</td>
            <td>@item.City?.NameAr</td>
            <td class="text-nowrap">
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تعديل</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">حذف</a>
            </td>
        </tr>
    }
    </tbody>
</table>