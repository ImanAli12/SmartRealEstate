@model RealEstateWebApp.Models.Property

@{
    var recommendationScore = ViewData["RecommendationScore"] as double?;
    var title = string.IsNullOrWhiteSpace(Model.Title) ? "عقار بدون عنوان" : Model.Title;
    var cityName = Model.City?.NameAr ?? "غير محدد";
    var priceCurrency = string.IsNullOrWhiteSpace(Model.PriceCurrency) ? "USD" : Model.PriceCurrency;
    var imageUrl = Model.Images.FirstOrDefault(i => i.IsMain)?.ImageUrl ?? Model.Images.FirstOrDefault()?.ImageUrl ?? "/images/no-image.svg";
}

<div class="col-12 col-md-6 col-xl-4">
    <div class="card h-100 position-relative">
        @if (recommendationScore.HasValue)
        {
            <div class="position-absolute top-0 start-0 m-2">
                <span class="badge bg-success">التطابق @recommendationScore.Value.ToString("F1")%</span>
            </div>
        }
        <img src="@imageUrl" class="card-img-top" alt="@title" style="height: 220px; object-fit: cover;" />
        <div class="card-body d-flex flex-column">
            <h5 class="card-title">@title</h5>
            <p class="small text-muted mb-2"><i class="bi bi-geo-alt"></i> @cityName</p>
            <p class="fw-bold text-primary mb-2">@Model.Price.ToString("N0") @priceCurrency</p>
            <div class="d-flex gap-3 mb-3 small">
                <span><i class="bi bi-door-open"></i> @Model.Rooms غرف</span>
                <span><i class="bi bi-aspect-ratio"></i> @Model.Area م²</span>
            </div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-controller="Favorites" asp-action="AddToFavorites" method="post" class="mb-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="propertyId" value="@Model.Id" />
                    <button class="btn btn-sm btn-outline-danger w-100" type="submit">إضافة إلى المفضلة</button>
                </form>
            }
            <a asp-controller="Properties" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary mt-auto">تفاصيل</a>
        </div>
    </div>
</div>