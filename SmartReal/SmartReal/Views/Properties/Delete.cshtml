@model RealEstateWebApp.Models.Property
@{
    ViewData["Title"] = "حذف العقار";
}

<div class="card p-4">
    <h1 class="h4 text-danger">تأكيد حذف العقار</h1>
    <p>هل تريد حذف العقار التالي نهائياً؟</p>
    <ul>
        <li><strong>العنوان:</strong> @Model.Title</li>
        <li><strong>المدينة:</strong> @Model.City?.NameAr</li>
        <li><strong>السعر:</strong> @Model.Price.ToString("N0") @Model.PriceCurrency</li>
    </ul>
    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">حذف</button>
        <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
    </form>
</div>