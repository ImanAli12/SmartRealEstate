@model RealEstateWebApp.Models.Neighborhood
@{
    ViewData["Title"] = "تعديل الحي";
}

<h1 class="h4 mb-3">تعديل حي</h1>

<form asp-action="Edit" method="post" class="card p-3">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="NameAr" class="form-label"></label>
        <input asp-for="NameAr" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="CityId" class="form-label">المدينة</label>
        <select asp-for="CityId" class="form-select" asp-items="ViewBag.CityId"></select>
    </div>
    <button class="btn btn-primary" type="submit">حفظ</button>
</form>