@model RealEstateWebApp.Services.KMeansTrainingReport

@{
    ViewData["Title"] = "تقرير K-Means";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">تقرير K-Means الأخير</h1>
        <p class="text-muted mb-0">تم التدريب في UTC: @Model.TrainedAtUtc.ToString("u")</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary btn-sm" asp-action="Dashboard">العودة للوحة الإدارة</a>
        <a class="btn btn-outline-secondary btn-sm" asp-action="DownloadKMeansFile" asp-route-fileName="report">تنزيل JSON</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card p-4 h-100">
            <div class="text-muted">عدد العقارات المدربة</div>
            <div class="display-6 mb-0">@Model.TrainedPropertiesCount</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-4 h-100">
            <div class="text-muted">عدد المجموعات K</div>
            <div class="display-6 mb-0">@Model.K</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-4 h-100">
            <div class="text-muted">عدد المراكز المعروضة</div>
            <div class="display-6 mb-0">@Model.Clusters.Count</div>
        </div>
    </div>
</div>

<div class="card p-4">
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Cluster</th>
                    <th>عدد النقاط</th>
                    <th>Area</th>
                    <th>Rooms</th>
                    <th>Floor</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Clusters)
                {
                    <tr>
                        <td>@item.Cluster</td>
                        <td>@item.PointsCount</td>
                        <td>@item.Area.ToString("F2")</td>
                        <td>@item.Rooms.ToString("F2")</td>
                        <td>@item.Floor.ToString("F2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>