@model IEnumerable<RealEstateWebApp.Models.Favorite>
@{
    ViewData["Title"] = "مفضلاتي";
}

<h1 class="h3 mb-4">مفضلاتي</h1>

<div class="row g-3">
    @if (!Model.Any())
    {
        <div class="col-12"><div class="alert alert-light border">لا يوجد عناصر في المفضلة.</div></div>
    }
    else
    {
        @foreach (var favorite in Model)
        {
            var property = favorite.Property;
            if (property is null)
            {
                continue;
            }

            <div class="col-12 col-lg-6">
                <div class="card p-3 h-100">
                    <h2 class="h5">@property.Title</h2>
                    <p class="mb-2">@property.City?.NameAr</p>
                    <p class="fw-bold text-primary">@property.Price.ToString("N0") @property.PriceCurrency</p>
                    <div class="d-flex gap-2 mt-auto">
                        <a asp-controller="Properties" asp-action="Details" asp-route-id="@property.Id" class="btn btn-outline-primary">تفاصيل</a>
                        <form asp-action="RemoveFromFavorites" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="propertyId" value="@property.Id" />
                            <button class="btn btn-outline-danger" type="submit">إزالة</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
</div>