@model List<Property>
@{
    ViewData["Title"] = "ابحث عن عقار | SYRELIS";
}

<div class="container">
    <div class="page-header">
        <h1 class="page-title"><i class="fa-solid fa-magnifying-glass"></i> ابحث عن عقارك</h1>
        <span class="page-subtitle"><i class="fa-regular fa-building"></i> حدد تفضيلاتك للعثور على العقار المناسب</span>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="icon-circle"><i class="fa-solid fa-sliders"></i></div>
            فلترة البحث
        </div>
        <form asp-controller="Property" asp-action="Search" method="get" id="searchForm" novalidate>
            <div class="search-grid">
                <div class="form-group">
                    <label><i class="fa-solid fa-building"></i> نوع العقار</label>
                    <select class="form-control" name="typeId">
                        <option value="">كل الأنواع</option>
                        @if (ViewBag.PropertyTypes != null)
                        {
                            foreach (var type in ViewBag.PropertyTypes)
                            {
                                <option value="@type.Id">@type.NameAr</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label><i class="fa-solid fa-tag"></i> طبيعة العقار</label>
                    <select class="form-control" name="status">
                        <option value="">الكل</option>
                        <option value="للبيع">للبيع</option>
                    </select>
                </div>
                <div class="form-group">
                    <label><i class="fa-solid fa-city"></i> المدينة</label>
                    <select class="form-control" name="cityId">
                        <option value="">كل المدن</option>
                        @if (ViewBag.Cities != null)
                        {
                            foreach (var city in ViewBag.Cities)
                            {
                                <option value="@city.Id">@city.NameAr</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label><i class="fa-solid fa-location-dot"></i> الحي</label>
                    <input type="text" class="form-control" name="neighborhood" placeholder="مثال: المالكي" />
                </div>
                <div class="form-group">
                    <label><i class="fa-solid fa-dollar-sign"></i> السعر (حد أقصى)</label>
                    <input type="number" class="form-control" name="maxPrice" placeholder="السعر" min="0" data-validate="positive" />
                    <span class="error-message" id="error-maxPrice"><i class="fa-solid fa-circle-exclamation"></i> قيمة صحيحة</span>
                </div>
                <div class="form-group">
                    <label><i class="fa-solid fa-coins"></i> العملة</label>
                    <select class="form-control" name="currency">
                        <option value="">الكل</option>
                        <option value="USD">دولار أمريكي</option>
                        <option value="SYP">ليرة سورية</option>
                    </select>
                </div>
                <div class="form-group">
                    <label><i class="fa-solid fa-vector-square"></i> المساحة (م²)</label>
                    <input type="number" class="form-control" name="minArea" placeholder="المساحة" min="0" data-validate="positive" />
                    <span class="error-message" id="error-minArea"><i class="fa-solid fa-circle-exclamation"></i> قيمة صحيحة</span>
                </div>
                <div class="form-group">
                    <label><i class="fa-solid fa-bed"></i> عدد الغرف</label>
                    <input type="number" class="form-control" name="rooms" placeholder="الغرف" min="0" data-validate="positive" />
                    <span class="error-message" id="error-rooms"><i class="fa-solid fa-circle-exclamation"></i> قيمة صحيحة</span>
                </div>
                <div class="form-group">
                    <label><i class="fa-solid fa-bath"></i> عدد الحمامات</label>
                    <input type="number" class="form-control" name="bathrooms" placeholder="الحمامات" min="0" data-validate="positive" />
                    <span class="error-message" id="error-bathrooms"><i class="fa-solid fa-circle-exclamation"></i> قيمة صحيحة</span>
                </div>
                <div class="form-group">
                    <label><i class="fa-solid fa-layer-group"></i> الطابق</label>
                    <input type="number" class="form-control" name="floor" placeholder="رقم الطابق" min="0" data-validate="positive" />
                    <span class="error-message" id="error-floor"><i class="fa-solid fa-circle-exclamation"></i> قيمة صحيحة</span>
                </div>
                <div class="form-group">
                    <label><i class="fa-solid fa-stairs"></i> عدد الطوابق الكلي</label>
                    <input type="number" class="form-control" name="totalFloors" placeholder="الطوابق" min="0" data-validate="positive" />
                    <span class="error-message" id="error-totalFloors"><i class="fa-solid fa-circle-exclamation"></i> قيمة صحيحة</span>
                </div>
            </div>
            <div class="form-actions">
                <div class="btn-group">
                    <button type="reset" class="btn btn-secondary" onclick="resetSearch()"><i class="fa-solid fa-rotate-right"></i> إعادة تعيين</button>
                </div>
                <div class="btn-group">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-magnifying-glass"></i> بحث</button>
                </div>
            </div>
        </form>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="results-section">
            <div class="results-count"><strong>@Model.Count</strong> عقار تم العثور عليه</div>
            <div class="property-grid">
                @foreach (var item in Model)
                {
                    var mainImage = item.Images.FirstOrDefault(i => i.IsMain)?.ImageUrl ?? "/images/default.jpg";
                    <div class="property-card" onclick="location.href='/Property/Details/@item.Id'" style="cursor:pointer;">
                        <div class="property-img">
                            <img src="@mainImage" alt="@item.Title" onerror="this.src='/images/default.jpg'" />
                            <span class="property-badge sale">@item.Status</span>
                        </div>
                        <div class="property-body">
                            <div class="property-price">@item.Price.ToString("N0") @item.PriceCurrency</div>
                            <div class="property-title">@item.Title</div>
                            <div class="property-location"><i class="fa-solid fa-location-dot"></i> @(item.City?.NameAr ?? "") - @(item.Neighborhood?.NameAr ?? "")</div>
                            <div class="property-features">
                                <span><i class="fa-solid fa-bed"></i> @item.Rooms</span>
                                <span><i class="fa-solid fa-bath"></i> @item.Bathrooms</span>
                                <span><i class="fa-solid fa-vector-square"></i> @item.Area م²</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else if (Model != null && !Model.Any())
    {
        <div class="empty-state" style="margin-top:30px;">
            <i class="fa-regular fa-face-frown"></i>
            <h3>لا توجد نتائج</h3>
            <p>لم نجد أي عقار يطابق معايير البحث. حاول تعديل الفلترة.</p>
        </div>
    }
</div>

<button class="scroll-top" id="scrollBtn" onclick="window.scrollTo({ top: 0, behavior: 'smooth' })">
    <i class="fa-solid fa-arrow-up"></i>
</button>

<script>
    window.addEventListener('scroll', function () {
        document.getElementById('scrollBtn').classList.toggle('show', window.scrollY > 300);
    });

    function resetSearch() {
        document.getElementById('searchForm').reset();
        document.querySelectorAll('select.form-control').forEach(select => select.selectedIndex = 0);
        document.querySelectorAll('.form-control.input-error').forEach(el => el.classList.remove('input-error'));
        document.querySelectorAll('.error-message.show').forEach(el => el.classList.remove('show'));
        window.location.href = '/Property/Search';
    }

    function validateField(input) {
        var val = input.value.trim();
        var errorId = 'error-' + input.name;
        var errorEl = document.getElementById(errorId);
        if (!errorEl) return true;
        if (val === '') {
            input.classList.remove('input-error');
            errorEl.classList.remove('show');
            return true;
        }
        var num = parseFloat(val);
        if (isNaN(num) || num < 0) {
            input.classList.add('input-error');
            errorEl.classList.add('show');
            return false;
        } else {
            input.classList.remove('input-error');
            errorEl.classList.remove('show');
            return true;
        }
    }

    document.querySelectorAll('input[data-validate]').forEach(function (input) {
        input.addEventListener('input', function () { validateField(this); });
        input.addEventListener('blur', function () { validateField(this); });
    });

    document.getElementById('searchForm').addEventListener('submit', function (e) {
        var valid = true;
        document.querySelectorAll('input[data-validate]').forEach(function (input) {
            if (!validateField(input)) valid = false;
        });
        if (!valid) {
            e.preventDefault();
            var firstError = document.querySelector('.form-control.input-error');
            if (firstError) firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    });
</script>