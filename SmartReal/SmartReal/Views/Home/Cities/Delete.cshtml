@model RealEstateWebApp.Models.City
@{
    ViewData["Title"] = "حذف مدينة";
}

<div class="card p-3">
    <h1 class="h5 text-danger">حذف المدينة</h1>
    <p>هل أنت متأكد من حذف: <strong>@Model.NameAr</strong>؟</p>
    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <button class="btn btn-danger" type="submit">حذف</button>
        <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
    </form>
</div>