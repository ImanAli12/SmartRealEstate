<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - عقارات الشام</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RealEstateWebApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header sticky-top">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-buildings"></i> عقارات الشام</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu" aria-controls="navMenu" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navMenu">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">الرئيسية</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Properties" asp-action="Index">العقارات</a></li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Properties" asp-action="Create">إضافة عقار</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Favorites" asp-action="MyFavorites">المفضلة</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Profile" asp-action="Index">حسابي</a></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="/Properties/Create">إضافة عقار</a></li>
                            <li class="nav-item"><a class="nav-link" asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="/Favorites/MyFavorites">المفضلة</a></li>
                            <li class="nav-item"><a class="nav-link" asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="/Profile/Index">حسابي</a></li>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">الإدارة</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Cities" asp-action="Index">المدن</a></li>
                                    <li><a class="dropdown-item" asp-controller="Neighborhoods" asp-action="Index">الأحياء</a></li>
                                    <li><a class="dropdown-item" asp-controller="PropertyTypes" asp-action="Index">الأنواع</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard">لوحة التحكم</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
                <div class="navbar-auth d-flex align-items-center gap-2 ms-lg-3 mt-3 mt-lg-0">
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main class="page-shell" role="main">
        <div class="container py-4">
            @if (TempData["SuccessMessage"] is string successMessage)
            {
                <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                    @successMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] is string errorMessage)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                    @errorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="pb-4">
                @RenderBody()
            </div>
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
