@model Property
@{
    ViewData["Title"] = Model.Title;
}

<div class="container" style="max-width:1000px;margin:40px auto;padding:30px;background:white;border-radius:24px;box-shadow:0 8px 30px rgba(0,0,0,0.1);">
    <h1 style="font-family:'Cinzel',serif;color:#0b1320;">@Model.Title</h1>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin:20px 0;">
        @foreach (var img in Model.Images)
        {
            <img src="@img.ImageUrl" alt="صورة" style="width:100%;height:200px;object-fit:cover;border-radius:12px;" />
        }
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
        <p><strong>السعر:</strong> @Model.Price.ToString("N0") @Model.PriceCurrency</p>
        <p><strong>المساحة:</strong> @Model.Area م²</p>
        <p><strong>الغرف:</strong> @Model.Rooms</p>
        <p><strong>الحمامات:</strong> @Model.Bathrooms</p>
        <p><strong>المدينة:</strong> @Model.City?.NameAr</p>
        <p><strong>الحي:</strong> @Model.Neighborhood?.NameAr</p>
        <p><strong>النوع:</strong> @Model.PropertyType?.NameAr</p>
        <p><strong>المعلن:</strong> @Model.Advertiser?.FullName</p>
    </div>
    <p><strong>الوصف:</strong> @Model.Description</p>
</div>