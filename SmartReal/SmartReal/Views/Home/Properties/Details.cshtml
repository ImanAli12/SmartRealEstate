@model RealEstateWebApp.Models.Property
@{
    ViewData["Title"] = "تفاصيل العقار";
    var similar = ViewBag.SimilarProperties as List<RealEstateWebApp.Models.Property> ?? new();
}

<div class="row g-4">
    <div class="col-lg-8">
        <div id="propertyCarousel" class="carousel slide card" data-bs-ride="carousel">
            <div class="carousel-inner">
                @if (Model.Images.Any())
                {
                    var orderedImages = Model.Images.OrderByDescending(i => i.IsMain).ThenBy(i => i.Order).ToList();
                    for (var i = 0; i < orderedImages.Count; i++)
                    {
                        <div class="carousel-item @(i == 0 ? "active" : string.Empty)">
                            <img src="@orderedImages[i].ImageUrl" class="d-block w-100" style="height: 420px; object-fit: cover;" alt="صورة العقار" />
                        </div>
                    }
                }
                else
                {
                    <div class="carousel-item active">
                        <img src="/images/no-image.svg" class="d-block w-100" style="height: 420px; object-fit: cover;" alt="لا توجد صورة" />
                    </div>
                }
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#propertyCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#propertyCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card p-3 mb-3">
            <h1 class="h4">@Model.Title</h1>
            <p class="fw-bold text-primary fs-4 mb-2">@Model.Price.ToString("N0") @Model.PriceCurrency</p>
            <p class="mb-2"><i class="bi bi-geo-alt"></i> @Model.City?.NameAr - @Model.Neighborhood?.NameAr</p>
            <p class="mb-2"><i class="bi bi-building"></i> @Model.PropertyType?.NameAr</p>
            <p class="mb-0"><i class="bi bi-tags"></i> @Model.Status</p>
        </div>
        <div class="card p-3">
            <form asp-controller="Favorites" asp-action="AddToFavorites" method="post" class="mb-2">
                @Html.AntiForgeryToken()
                <input type="hidden" name="propertyId" value="@Model.Id" />
                <button class="btn btn-outline-primary w-100" type="submit">إضافة إلى المفضلة</button>
            </form>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="alert alert-light mb-0">رقم المعلن: @Model.Advertiser?.PhoneNumber</div>
            }
            else
            {
                <div class="alert alert-warning mb-0">سجّل الدخول لرؤية رقم المعلن.</div>
            }
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-lg-6">
        <div class="card p-3 h-100">
            <h2 class="h5">معلومات أساسية</h2>
            <div class="row">
                <div class="col-6 mb-2">المساحة: <strong>@Model.Area م²</strong></div>
                <div class="col-6 mb-2">الغرف: <strong>@Model.Rooms</strong></div>
                <div class="col-6 mb-2">الحمامات: <strong>@Model.Bathrooms</strong></div>
                <div class="col-6 mb-2">الطابق: <strong>@(Model.Floor?.ToString() ?? "-")</strong></div>
                <div class="col-12 mb-2">العنوان: <strong>@Model.Address</strong></div>
                <div class="col-12">المجموعة: <strong>@(Model.Cluster?.NameAr ?? "غير مصنف")</strong></div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card p-3 h-100">
            <h2 class="h5">الموقع</h2>
            @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
            {
                <iframe
                    width="100%"
                    height="280"
                    style="border:0"
                    loading="lazy"
                    allowfullscreen
                    src="https://maps.google.com/maps?q=@Model.Latitude,@Model.Longitude&hl=ar&z=14&output=embed">
                </iframe>
            }
            else
            {
                <div class="alert alert-secondary mb-0">الموقع غير محدد.</div>
            }
        </div>
    </div>
</div>

<section class="mt-4">
    <div class="card p-3">
        <h2 class="h5">الوصف</h2>
        <p class="mb-0">@Model.Description</p>
    </div>
</section>

<section class="mt-4">
    <h2 class="h5 mb-3">عقارات مشابهة</h2>
    <div class="row g-3">
        @if (!similar.Any())
        {
            <div class="col-12"><div class="alert alert-light border">لا توجد توصيات حالياً.</div></div>
        }
        else
        {
            @foreach (var property in similar)
            {
                @await Html.PartialAsync("_PropertyCard", property)
            }
        }
    </div>
</section>