@model RealEstateWebApp.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "لوحة الإدارة";
}

<h1 class="h3 mb-4">لوحة إدارة النظام</h1>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card p-4 h-100">
            <h2 class="h5">تطبيق خوارزمية K-Means</h2>
            <p>استخدم هذا الإجراء لتحديث التجميعات الذكية للعقارات.</p>
            <form asp-action="RunKMeans" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label for="k" class="form-label">عدد المجموعات</label>
                    <input id="k" name="k" class="form-control" type="number" min="2" max="12" value="5" />
                </div>
                <button class="btn btn-primary" type="submit">تطبيق الخوارزمية</button>
            </form>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card p-4 h-100">
            <h2 class="h5">استيراد بيانات تجريبية</h2>
            <p>استيراد ملف Excel من جذر المشروع مع CSV احتياطي لإضافة عقارات تجريبية.</p>
            <form asp-action="ImportSampleCsv" method="post">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-primary" type="submit">استيراد Excel</button>
            </form>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-12">
        <div class="card p-4">
            <h2 class="h5">نتائج آخر تدريب K-Means</h2>
            <p class="text-muted mb-3">
                هذا التقرير يوضح كيف قُسِّمت العقارات إلى مجموعات متشابهة حسب Area وRooms وFloor،
                حتى تقدر تميز الأنماط وتعرض أو تقترح عقارات أقرب لاهتمامات المستخدم.
            </p>
            <p class="mb-2">عدد العقارات النشطة في قاعدة البيانات: <strong>@Model.ActivePropertiesCount</strong></p>
            <p class="mb-3">
                حالة الملفات:
                <span class="badge text-bg-@(Model.NormalizerFileExists ? "success" : "secondary")">normalizer.json</span>
                <span class="badge text-bg-@(Model.CentroidsFileExists ? "success" : "secondary")">centroids.json</span>
            </p>

            <div class="d-flex flex-wrap gap-2 mb-3">
                <a class="btn btn-success btn-sm" asp-action="KMeansReport">عرض صفحة التقرير</a>
                <a class="btn btn-outline-secondary btn-sm" asp-action="DownloadKMeansFile" asp-route-fileName="report">تنزيل report.json</a>
                <a class="btn btn-outline-secondary btn-sm" asp-action="DownloadKMeansFile" asp-route-fileName="centroids">تنزيل centroids.json</a>
                <a class="btn btn-outline-secondary btn-sm" asp-action="DownloadKMeansFile" asp-route-fileName="normalizer">تنزيل normalizer.json</a>
            </div>

            @if (Model.LatestKMeansReport is null)
            {
                <div class="alert alert-warning mb-0">
                    لا يوجد تقرير تدريب بعد. شغل الخوارزمية من الزر أعلاه وسيتم إنشاء التقرير.
                </div>
            }
            else
            {
                <div class="mb-3">
                    <div>وقت التدريب (UTC): <strong>@Model.LatestKMeansReport.TrainedAtUtc.ToString("u")</strong></div>
                    <div>عدد المجموعات K: <strong>@Model.LatestKMeansReport.K</strong></div>
                    <div>عدد العقارات المدربة: <strong>@Model.LatestKMeansReport.TrainedPropertiesCount</strong></div>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Cluster</th>
                                <th>عدد النقاط</th>
                                <th>Area</th>
                                <th>Rooms</th>
                                <th>Floor</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.LatestKMeansReport.Clusters)
                            {
                                <tr>
                                    <td>@item.Cluster</td>
                                    <td>@item.PointsCount</td>
                                    <td>@item.Area.ToString("F2")</td>
                                    <td>@item.Rooms.ToString("F2")</td>
                                    <td>@item.Floor.ToString("F2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>